ENVIRONMENT=development
SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=neuralalpha
MYSQL_USER=neuralalpha
MYSQL_PASSWORD=neuralalpha
MYSQL_ROOT_PASSWORD=change-me-root
DATABASE_URL=mysql+aiomysql://neuralalpha:neuralalpha@mysql:3306/neuralalpha

REDIS_URL=redis://redis:6379/0
VECTOR_DB_PROVIDER=chroma
CORS_ALLOWED_ORIGINS=http://localhost:5173
PUBLIC_API_KEY=replace-with-strong-random-api-key
API_KEY_REQUIRED=true
API_KEY_ALLOWED_IPS=127.0.0.1

VITE_API_URL=/api/v1

GEMINI_API_KEY=replace-with-your-provider-key
GEMINI_MODEL=gemini-2.0-flash
NEWS_API_KEY=your_newsapi_key_here
ENFORCE_REAL_MODELS=false
STRICT_API_VALIDATION=true
MODEL_VERSION=v1
MODEL_PATH=ml_pipeline/models/lstm_close.keras
SCALER_PATH=ml_pipeline/models/close_scaler.pkl
XGBOOST_MODEL_PATH=ml_pipeline/models/xgb.joblib
LSTM_WINDOW_SIZE=10
LSTM_UNITS=64
LSTM_EPOCHS=20
LSTM_BATCH_SIZE=32
LSTM_MAX_ROWS=20000
MONITORING_DB_PATH=backend/data/observability.db
MONITORING_WINDOW_SIZE=100
MONITORING_MAE_THRESHOLD=5.0
MONITORING_LATENCY_THRESHOLD_MS=500.0
MONITORING_SLO_LATENCY_MS=3000
MONITORING_SLO_ERROR_RATE=0.01
MONITORING_ANOMALY_MULTIPLIER=1.5
MONITORING_FALLBACK_ALERT=0.2
CACHE_TTL_SECONDS=300
PROMPT_VARIANT=A
PROMPT_MAX_CONTEXT_CHARS=800
LLM_MAX_TOKENS=220
LLM_TEMPERATURE=0.1
